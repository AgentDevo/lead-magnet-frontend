'use client'

import { useState, useEffect } from 'react'
import { Activity, Coffee, Zap } from 'lucide-react'
import { cn } from '@/lib/utils'

interface Agent {
  id: string
  name: string
  status: 'active' | 'inactive' | 'paused'
  model: string
  currentTask?: string
}

interface OfficeViewProps {
  agents: Agent[]
  activeTasks: Array<{ agentId: string; taskName: string }>
}

const PacmanMonster = ({
  agent,
  position,
  isWorking,
  taskName
}: {
  agent: Agent
  position: { x: number; y: number }
  isWorking: boolean
  taskName?: string
}) => {
  const colorMap: Record<string, string> = {
    '1': '#ffa500', // Devo - orange
    '2': '#ff69b4', // Memory Curator - pink
    '3': '#00bfff', // Network Monitor - cyan
  }

  const color = colorMap[agent.id] || '#ffa500'

  return (
    <div
      className="absolute transition-all duration-300"
      style={{
        left: `${position.x}px`,
        top: `${position.y}px`
      }}
    >
      {/* Pac-Man Style Monster - 8x8 pixels */}
      <svg width="16" height="16" viewBox="0 0 16 16" style={{ imageRendering: 'pixelated' }}>
        {/* Body - rounded square (Pac-Man shape) */}
        <circle cx="8" cy="8" r="7" fill={color} />
        
        {/* Mouth (opening on right side) */}
        <polygon points="8,8 14,4 14,12" fill="#0f0f0f" />

        {/* Eyes */}
        <circle cx="5" cy="5" r="1.5" fill="white" />
        <circle cx="5" cy="11" r="1.5" fill="white" />
        
        {/* Eye pupils */}
        <circle cx="5" cy="5" r="0.8" fill="black" />
        <circle cx="5" cy="11" r="0.8" fill="black" />
      </svg>

      {/* Status Indicator */}
      <div className="absolute -top-3 left-1/2 transform -translate-x-1/2">
        {isWorking ? (
          <div className="flex items-center gap-0.5">
            <div className="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse" />
            <span className="text-[8px] text-green-400 font-bold">✓</span>
          </div>
        ) : agent.status === 'active' ? (
          <div className="w-1.5 h-1.5 rounded-full bg-blue-400" />
        ) : (
          <div className="w-1.5 h-1.5 rounded-full bg-gray-500" />
        )}
      </div>

      {/* Name Label */}
      <div className="absolute -top-8 left-1/2 transform -translate-x-1/2 whitespace-nowrap">
        <div className="text-[9px] font-bold text-white bg-[#1a1a1a] px-1 py-0.5 rounded border border-[#27272a]">
          {agent.name}
        </div>
      </div>

      {/* Task Label */}
      {taskName && (
        <div className="absolute top-6 left-1/2 transform -translate-x-1/2 whitespace-nowrap">
          <div className="text-[8px] text-[#a1a1aa] bg-[#161616] px-1 py-0.5 rounded border border-[#27272a]">
            {taskName.length > 15 ? taskName.substring(0, 15) + '...' : taskName}
          </div>
        </div>
      )}
    </div>
  )
}

const MeetingRoom = ({
  position,
  agents
}: {
  position: { x: number; y: number }
  agents: Agent[]
}) => {
  return (
    <div
      className="absolute"
      style={{
        left: `${position.x - 50}px`,
        top: `${position.y - 40}px`
      }}
    >
      {/* Meeting Room Wall Outline */}
      <div className="w-40 h-32 border-4 border-[#404040] rounded-lg bg-[#1a1a1a] shadow-xl">
        {/* Room interior */}
        <div className="w-full h-full p-3 flex flex-col items-center justify-between">
          {/* Title */}
          <div className="text-[9px] font-bold text-white bg-[#0f0f0f] px-2 py-1 rounded border border-[#27272a]">
            💡 Brainstorm Room
          </div>

          {/* Meeting Table */}
          <div className="w-20 h-12 border-2 border-[#8b7355] rounded-lg bg-[#7a6b4f] flex items-center justify-center">
            <div className="text-[8px] text-[#1a1a1a] font-bold">🪑 TABLE 🪑</div>
          </div>

          {/* Agent indicators around table */}
          <div className="flex gap-2">
            {agents.slice(0, 3).map((agent, idx) => {
              const colorMap: Record<string, string> = {
                '1': '#ffa500',
                '2': '#ff69b4',
                '3': '#00bfff',
              }
              return (
                <div
                  key={idx}
                  className="w-2.5 h-2.5 rounded-full"
                  style={{
                    backgroundColor: colorMap[agent.id] || '#ffa500'
                  }}
                />
              )
            })}
          </div>
        </div>
      </div>

      {/* Door */}
      <div className="absolute -left-4 top-6 w-3 h-6 border-2 border-[#8b7355] bg-[#6b5344] rounded-sm" />
    </div>
  )
}

const Desk = ({
  position,
  hasAgent,
  agentName
}: {
  position: { x: number; y: number }
  hasAgent: boolean
  agentName?: string
}) => {
  return (
    <div
      className="absolute"
      style={{
        left: `${position.x}px`,
        top: `${position.y}px`
      }}
    >
      {/* Monitor Stand */}
      <div className="absolute -top-12 left-2 w-10 h-1 bg-[#5a4a3a] rounded-sm" />

      {/* Monitor Screen */}
      <div className="absolute -top-12 left-1 w-12 h-9 bg-[#1a1a1a] border-2 border-[#333333] rounded-sm shadow-lg">
        {/* Screen bezel */}
        <div className="w-full h-full p-1 bg-[#2a2a2a]">
          {/* Screen display - animated */}
          <div className="w-full h-full bg-gradient-to-b from-[#0a3a5a] to-[#052a3a] flex items-center justify-center relative overflow-hidden">
            {/* Scanlines effect */}
            <div className="absolute inset-0 opacity-20">
              {Array.from({ length: 8 }).map((_, i) => (
                <div key={i} className="h-0.5 bg-[#00ff00] opacity-30" />
              ))}
            </div>
            {/* Active indicator */}
            <div className="absolute top-1 right-1 w-1 h-1 rounded-full bg-[#00ff00] animate-pulse" />
            {/* Cursor blink */}
            <div className="text-[6px] text-[#00ff00] font-bold">▓</div>
          </div>
        </div>

        {/* Monitor bottom bezel */}
        <div className="absolute bottom-0 left-0 right-0 h-1 bg-[#3a3a3a]" />
      </div>

      {/* Desk Surface */}
      <div className="w-14 h-7 bg-[#8b7355] border-2 border-[#6b5344] rounded-sm shadow-lg">
        {/* Desktop surface */}
        <div className="w-full h-full flex items-center justify-center">
          <div className="w-10 h-5 bg-[#7a6b4f] rounded-sm opacity-80" />
          {/* Keyboard area */}
          <div className="absolute bottom-1 left-2 w-8 h-1 bg-[#4a4a4a] rounded-sm opacity-60" />
        </div>
      </div>

      {/* Desk Legs */}
      <div className="flex gap-10 px-1 mt-0.5 absolute bottom-0 left-0 right-0">
        <div className="w-1.5 h-3 bg-[#6b5344] rounded-sm" />
        <div className="w-1.5 h-3 bg-[#6b5344] rounded-sm" />
      </div>

      {/* Office Chair (back) */}
      <div className="absolute -left-2 top-2 w-2 h-4 bg-[#4a3a2a] rounded-full opacity-70" />

      {/* Label */}
      {agentName && (
        <div className="text-[8px] text-[#71717a] text-center mt-2">
          {agentName.split(' ')[0]}
        </div>
      )}
    </div>
  )
}

export default function OfficeView({ agents, activeTasks }: OfficeViewProps) {
  const [agentPositions, setAgentPositions] = useState<
    Record<string, { x: number; y: number }>
  >({})
  const [chatMessage, setChatMessage] = useState('')
  const [chatHistory, setChatHistory] = useState<Array<{ sender: string; message: string }>>([
    { sender: 'System', message: '👾 Welcome to Devo\'s Office! Give instructions to the agents.' }
  ])

  // Desk positions - ergonomic U-shape layout around meeting room
  const deskPositions: Record<string, { x: number; y: number }> = {
    '1': { x: 120, y: 100 },   // Devo - left side
    '2': { x: 480, y: 100 },   // Memory Curator - right side
    '3': { x: 300, y: 320 },   // Network Monitor - bottom
  }

  // Meeting room center position
  const meetingRoomCenter = { x: 300, y: 180 }

  // Coffee area position
  const coffeeArea = { x: 600, y: 120 }

  // Initialize and update agent positions
  useEffect(() => {
    const positions: Record<string, { x: number; y: number }> = {}
    
    // Check if multiple agents are working (brainstorming)
    const workingAgents = agents.filter(a => activeTasks.some(t => t.agentId === a.id))
    const isBrainstorming = workingAgents.length > 1

    agents.forEach(agent => {
      const isWorking = activeTasks.some(t => t.agentId === agent.id)

      if (isBrainstorming && isWorking) {
        // Agent is in brainstorming/meeting room
        const angle = (parseInt(agent.id) * 120) * (Math.PI / 180)
        const radius = 45
        positions[agent.id] = {
          x: meetingRoomCenter.x + Math.cos(angle) * radius,
          y: meetingRoomCenter.y + Math.sin(angle) * radius + 20
        }
      } else if (isWorking) {
        // Agent is at desk working alone
        positions[agent.id] = deskPositions[agent.id] || { x: 80, y: 120 }
      } else {
        // Agent is at coffee/idle area
        const randomOffset = parseInt(agent.id) * 15
        positions[agent.id] = {
          x: coffeeArea.x + randomOffset,
          y: coffeeArea.y
        }
      }
    })

    setAgentPositions(positions)
  }, [activeTasks, agents])

  const handleSendMessage = () => {
    if (!chatMessage.trim()) return

    // Add user message to chat
    setChatHistory(prev => [...prev, { sender: 'You', message: chatMessage }])

    // Simulate agent response
    setTimeout(() => {
      setChatHistory(prev => [...prev, { sender: '👾 Devo', message: `Working on: "${chatMessage}"` }])
    }, 500)

    setChatMessage('')
  }

  return (
    <div className="flex flex-col h-full bg-[#0f0f0f] rounded-lg border border-[#27272a] overflow-hidden">
      {/* Header */}
      <div className="border-b border-[#27272a] bg-[#111111] px-6 py-4">
        <h2 className="text-lg font-semibold text-white mb-2">🏢 Devo's Office</h2>
        <p className="text-xs text-[#71717a]">
          Ergonomic U-shaped workspace. Give instructions to agents via chat! 👾💡
        </p>
      </div>

      {/* Main Content */}
      <div className="flex flex-1 min-h-0 overflow-hidden">
        {/* Left: Office Canvas */}
        <div className="flex-1 overflow-hidden bg-gradient-to-b from-[#1a1a1a] to-[#0f0f0f] relative">
        {/* Pixel art office background */}
        <svg
          className="absolute inset-0 w-full h-full"
          style={{ imageRendering: 'pixelated' }}
        >
          {/* Floor tiles */}
          {Array.from({ length: 20 }).map((_, i) =>
            Array.from({ length: 12 }).map((_, j) => (
              <rect
                key={`tile-${i}-${j}`}
                x={i * 24}
                y={j * 24}
                width={24}
                height={24}
                fill={(i + j) % 2 === 0 ? '#1f1f1f' : '#1a1a1a'}
                stroke="#27272a"
                strokeWidth="0.5"
              />
            ))
          )}

          {/* Grid lines */}
          {Array.from({ length: 20 }).map((_, i) => (
            <line
              key={`vline-${i}`}
              x1={i * 24}
              y1={0}
              x2={i * 24}
              y2="100%"
              stroke="#27272a"
              strokeWidth="0.5"
              opacity="0.3"
            />
          ))}
          {Array.from({ length: 12 }).map((_, i) => (
            <line
              key={`hline-${i}`}
              x1={0}
              y1={i * 24}
              x2="100%"
              y2={i * 24}
              stroke="#27272a"
              strokeWidth="0.5"
              opacity="0.3"
            />
          ))}
        </svg>

        {/* Office furniture and zones */}
        <div className="absolute inset-0 pointer-events-none" style={{ padding: '20px' }}>
          {/* Desks */}
          <div className="relative w-full h-full">
            {/* Check if brainstorming */}
            {(() => {
              const workingAgents = agents.filter(a => activeTasks.some(t => t.agentId === a.id))
              const isBrainstorming = workingAgents.length > 1
              if (isBrainstorming) {
                return <MeetingRoom position={meetingRoomCenter} agents={workingAgents} />
              } else {
                return Object.entries(deskPositions).map(([agentId, pos]) => {
                  const agent = agents.find(a => a.id === agentId)
                  const isActive = activeTasks.some(t => t.agentId === agentId)
                  return agent && isActive ? (
                    <Desk
                      key={`desk-${agentId}`}
                      position={pos}
                      hasAgent={true}
                      agentName={agent.name}
                    />
                  ) : null
                })
              }
            })()}

            {/* Coffee corner sign */}
            <div
              className="absolute"
              style={{
                left: `${coffeeArea.x - 20}px`,
                top: `${coffeeArea.y - 30}px`
              }}
            >
              <div className="text-[10px] font-bold text-[#f59e0b] bg-[#1a1a1a] px-2 py-1 rounded border border-[#f59e0b]">
                ☕ Break Room
              </div>
            </div>

            {/* Meeting room zone marker */}
            <div
              className="absolute"
              style={{
                left: `${meetingRoomCenter.x - 50}px`,
                top: `${meetingRoomCenter.y - 60}px`
              }}
            >
              <div className="text-[9px] font-bold text-cyan-400 bg-[#1a1a1a] px-2 py-1 rounded border border-cyan-500/50">
                💡 BRAINSTORM
              </div>
            </div>

            {/* Agents (Pac-Man Monsters) */}
            {agents.map(agent => {
              const pos = agentPositions[agent.id]
              const task = activeTasks.find(t => t.agentId === agent.id)

              return pos ? (
                <PacmanMonster
                  key={`agent-${agent.id}`}
                  agent={agent}
                  position={pos}
                  isWorking={!!task}
                  taskName={task?.taskName}
                />
              ) : null
            })}
          </div>
        </div>

        {/* Status Board */}
        <div className="absolute bottom-4 right-4 bg-[#161616] border-2 border-[#27272a] rounded p-3 space-y-2 max-w-xs">
          <div className="text-xs font-bold text-white mb-2">📊 Status</div>
          {(() => {
            const workingAgents = agents.filter(a => activeTasks.some(t => t.agentId === a.id))
            const isBrainstorming = workingAgents.length > 1
            
            return agents.map(agent => {
              const task = activeTasks.find(t => t.agentId === agent.id)
              return (
                <div
                  key={`status-${agent.id}`}
                  className="text-[10px] flex items-center justify-between p-1 bg-[#0f0f0f] rounded"
                >
                  <span className="text-[#a1a1aa]">{agent.name}</span>
                  {task && isBrainstorming ? (
                    <span className="text-cyan-400 flex items-center gap-1">
                      <Zap className="w-3 h-3" />
                      Brainstorming
                    </span>
                  ) : task ? (
                    <span className="text-green-400 flex items-center gap-1">
                      <Activity className="w-3 h-3" />
                      Working
                    </span>
                  ) : agent.status === 'active' ? (
                    <span className="text-blue-400 flex items-center gap-1">
                      <Coffee className="w-3 h-3" />
                      Break
                    </span>
                  ) : (
                    <span className="text-[#52525b]">Offline</span>
                  )}
                </div>
              )
            })
          })()}
        </div>

        {/* Right: Chat Panel */}
        <div className="w-80 flex flex-col border-l border-[#27272a] bg-[#0f0f0f]">
        {/* Chat Header */}
        <div className="border-b border-[#27272a] bg-[#111111] px-4 py-3">
          <h3 className="text-sm font-semibold text-white flex items-center gap-2">
            💬 Agent Instructions
          </h3>
          <p className="text-xs text-[#52525b] mt-1">Give tasks to the team</p>
        </div>

        {/* Chat History */}
        <div className="flex-1 overflow-y-auto p-3 space-y-2">
          {chatHistory.map((msg, idx) => (
            <div key={idx} className="text-xs space-y-0.5">
              <div className={cn(
                'font-semibold',
                msg.sender === 'You' ? 'text-indigo-400' : 'text-[#71717a]'
              )}>
                {msg.sender}
              </div>
              <div className="text-[#e4e4e7] bg-[#161616] rounded p-2 leading-relaxed">
                {msg.message}
              </div>
            </div>
          ))}
        </div>

        {/* Input Area */}
        <div className="border-t border-[#27272a] bg-[#111111] p-3 space-y-2">
          <input
            type="text"
            value={chatMessage}
            onChange={(e) => setChatMessage(e.target.value)}
            onKeyPress={(e) => {
              if (e.key === 'Enter') handleSendMessage()
            }}
            placeholder="Type instruction..."
            className="w-full px-3 py-2 rounded-lg bg-[#161616] border border-[#27272a] text-xs text-[#e4e4e7] placeholder-[#52525b] focus:border-indigo-500/50 focus:outline-none"
          />
          <button
            onClick={handleSendMessage}
            className="w-full px-3 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-xs font-medium text-white transition-colors"
          >
            Send Instruction
          </button>
        </div>

        {/* Legend */}
        <div className="border-t border-[#27272a] bg-[#111111] px-3 py-2 text-[10px] text-[#71717a] space-y-1.5">
          <div className="font-semibold text-[#a1a1aa] uppercase tracking-wider mb-1">
            Status Codes
          </div>
          <div className="space-y-1">
            <div className="flex items-center gap-2">
              <span className="inline-block w-1.5 h-1.5 rounded-full bg-green-400" />
              <span>Working</span>
            </div>
            <div className="flex items-center gap-2">
              <span className="inline-block w-1.5 h-1.5 rounded-full bg-cyan-400" />
              <span>Brainstorming</span>
            </div>
            <div className="flex items-center gap-2">
              <span className="inline-block w-1.5 h-1.5 rounded-full bg-blue-400" />
              <span>Break</span>
            </div>
          </div>
          <div className="border-t border-[#27272a] pt-1.5 mt-1.5 space-y-0.5">
            <div><span style={{ color: '#ffa500' }}>🟠 Devo</span></div>
            <div><span style={{ color: '#ff69b4' }}>🟥 Memory</span></div>
            <div><span style={{ color: '#00bfff' }}>🟦 Network</span></div>
          </div>
        </div>
      </div>
    </div>
  )
}
