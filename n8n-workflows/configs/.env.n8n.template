# n8n Workflow Configuration
# Copy this to .env.n8n and fill in your actual values

# ===== n8n Core =====
NODE_ENV=production
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_PATH=/
WEBHOOK_URL=http://localhost:5678

# ===== Database =====
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n_user
DB_POSTGRESDB_PASSWORD=your_secure_password_here
DB_POSTGRESDB_SSL=false

# ===== Supabase =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ===== Backend API =====
BACKEND_API_URL=http://localhost:3001
BACKEND_API_KEY=your-backend-api-key
BACKEND_JWT_SECRET=your-jwt-secret

# ===== OpenAI API =====
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ===== Gmail SMTP =====
GMAIL_USER=noreply@example.com
GMAIL_PASSWORD=your-app-password
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_FROM_EMAIL=noreply@example.com
GMAIL_FROM_NAME=Lead Magnet Platform

# ===== Mailchimp =====
MAILCHIMP_API_KEY=your-mailchimp-api-key
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=your-mailchimp-list-id

# ===== ConvertKit =====
CONVERTKIT_API_KEY=your-convertkit-api-key
CONVERTKIT_API_SECRET=your-convertkit-api-secret
CONVERTKIT_FORM_ID=your-convertkit-form-id

# ===== HubSpot =====
HUBSPOT_API_KEY=your-hubspot-api-key
HUBSPOT_ACCOUNT_ID=your-hubspot-account-id

# ===== Application Settings =====
USER_ID=default-user-uuid
USER_EMAIL=admin@example.com
ADMIN_EMAIL=admin@example.com

# ===== Logging =====
LOG_LEVEL=info
LOG_OUTPUT=console,file

# ===== Security =====
ENCRYPTION_KEY=your-encryption-key-32-chars-min
WEBHOOK_AUTH_KEY=your-webhook-auth-key

# ===== Execution Settings =====
EXECUTIONS_PROCESS=main
EXECUTIONS_MODE=queue
EXECUTIONS_TIMEOUT_HH=1
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_SAVE_ON_SUCCESS=all

# ===== External Service Timeouts (seconds) =====
HTTP_REQUEST_TIMEOUT=30
OPENAI_REQUEST_TIMEOUT=35
PDF_GENERATION_TIMEOUT=60

# ===== Rate Limiting =====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ===== Slack Integration (Optional) =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#notifications
SLACK_USERNAME=n8n-bot

# ===== Redis (Optional - for caching) =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== Features =====
FEATURE_ANALYTICS=true
FEATURE_EMAIL_SYNC=true
FEATURE_PDF_GENERATION=true
